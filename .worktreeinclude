# .worktreeinclude
# Files that are gitignored but get copied into every new worktree
# by `claude --worktree`. Without these, agents can't connect to
# Supabase and all DB calls fail immediately.
#
# Syntax: same glob patterns as .gitignore

# Local env — Supabase URL, anon key, service role key, etc.
.env.local

# Any other per-environment overrides that may exist locally
.env.development.local
.env.test.local
.env.production.local
