# .worktreeinclude
# Archivos gitignored que Claude Code copia automáticamente
# a cada nuevo worktree al crearlo con claude --worktree
#
# Sintaxis igual a .gitignore (patrones glob)
# Sin este archivo, los agentes en worktrees no tienen
# variables de entorno y fallan en el primer test de BD.

# Variables de entorno
.env
.env.local
.env.development
.env.test
.env.production

# Configuración local que no va al repo
.env.*.local

